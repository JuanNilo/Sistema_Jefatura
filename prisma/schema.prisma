generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  WAITING_STUDENT
  CLOSED
}

enum CasePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum StudentStatus {
  ACTIVE
  ALUMNI
  SUSPENDED
}

model User {
  id              String        @id @default(cuid())
  name            String
  email           String        @unique
  passwordHash    String
  role            Role          @default(USER)
  casesResponsible Case[]       @relation("CaseResponsible")
  casesCreated    Case[]        @relation("CaseCreated")
  comments        CaseComment[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Student {
  id          String         @id @default(cuid())
  fullName    String
  studentCode String         @unique
  email       String?
  phone       String?
  career      String?
  status      StudentStatus  @default(ACTIVE)
  cases       Case[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model Case {
  id                String        @id @default(cuid())
  title             String
  description       String
  status            CaseStatus    @default(OPEN)
  priority          CasePriority  @default(MEDIUM)
  nextAction        String?
  dueDate           DateTime?
  student           Student       @relation(fields: [studentId], references: [id])
  studentId         String
  responsible       User          @relation("CaseResponsible", fields: [responsibleUserId], references: [id])
  responsibleUserId String
  createdBy         User          @relation("CaseCreated", fields: [createdByUserId], references: [id])
  createdByUserId   String
  comments          CaseComment[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  closedAt          DateTime?
}

model CaseComment {
  id           String   @id @default(cuid())
  case         Case     @relation(fields: [caseId], references: [id])
  caseId       String
  author       User     @relation(fields: [authorUserId], references: [id])
  authorUserId String
  content      String
  createdAt    DateTime @default(now())
}

