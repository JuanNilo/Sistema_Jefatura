generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum CaseStatus {
  NEW
  IN_REVIEW
  PENDING_STUDENT
  REFERRED
  FOLLOW_UP
  RESOLVED
  CLOSED
}

enum CasePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CaseType {
  ACADEMIC
  PERSONAL
  ATTENDANCE
  REINTEGRATION
  COURSE_LOAD
  SCHEDULE_CONFLICT
  INTERNSHIP
  BENEFITS
  COEXISTENCE
  INSTITUTIONAL_REFERRAL
  OTHER
}

enum CommentType {
  NOTE
  CONTACT
  AGREEMENT
  REFERRAL
  STATUS_UPDATE
  CLOSURE
}

enum CaseVisibility {
  PRIVATE
  TEAM
  INSTITUTION
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  passwordHash  String?
  role          Role           @default(USER)
  isActive      Boolean        @default(true)

  casesCreated  Case[]         @relation("CasesCreated")
  casesAssigned Case[]         @relation("CasesAssigned")
  comments      CaseComment[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Student {
  id          String   @id @default(cuid())
  fullName    String
  email       String?
  studentCode String?  @unique
  career      String?
  notes       String?

  cases       Case[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Case {
  id            String        @id @default(cuid())

  student       Student       @relation(fields: [studentId], references: [id])
  studentId     String

  title         String
  description   String
  caseType      CaseType
  priority      CasePriority  @default(MEDIUM)
  status        CaseStatus    @default(NEW)
  nextAction    String?
  dueDate       DateTime?
  visibility    CaseVisibility?

  createdBy     User          @relation("CasesCreated",  fields: [createdById], references: [id])
  createdById   String

  assignedTo    User          @relation("CasesAssigned", fields: [assignedToId], references: [id])
  assignedToId  String

  comments      CaseComment[]

  openedAt      DateTime      @default(now())
  closedAt      DateTime?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model CaseComment {
  id          String       @id @default(cuid())

  case        Case         @relation(fields: [caseId], references: [id])
  caseId      String

  author      User         @relation(fields: [authorId], references: [id])
  authorId    String

  content     String
  commentType CommentType

  createdAt   DateTime     @default(now())
}
